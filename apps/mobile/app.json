{
  "expo": {
    "name": "StudyPass",
    "slug": "studypass",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "studypass",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.studypass.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563eb"
      },
      "package": "com.studypass.app"
    },
    "plugins": ["expo-router"]
  }
}
